{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": ["vitest.mutation.config.ts"],
  "workspaces": {
    "services/wallet-service": {
      "entry": ["src/server.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "services/statement-service": {
      "entry": ["src/server.ts", "src/main.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/contracts": {
      "entry": ["src/index.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "tools": {
      "entry": [
        "derive-tier-cli.ts",
        "derive-tier.test.ts",
        "trace-coverage-cli.ts",
        "trace-coverage.test.ts"
      ],
      "project": ["*.ts"]
    }
  }
}
